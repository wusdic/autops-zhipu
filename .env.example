# AUTOPS 环境变量配置
# 复制为 .env 后按实际环境修改。生产环境所有标 [必改] 的项必须设置。

# ===== 运行环境 =====
AUTOPS_ENV=dev                       # dev / test / prod
AUTOPS_CONFIG_DIR=                   # configs 目录绝对路径，留空用默认

# ===== 数据库 (MySQL 8.0+) =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=autops
DB_PASS=change_me_in_production      # [必改] 应用账号密码
DB_DATABASE=autops
MYSQL_ROOT_PASSWORD=change_me_root   # [必改] docker-compose 启动 MySQL 必需，未设置容器无法启动

# ===== Redis (7.0+) =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=                          # 生产建议设置 requirepass
REDIS_DB=0

# ===== 安全 / JWT =====
# [必改] 生产必须 >=32 字符且不能是占位值，否则启动报错（INSECURE_SECRETS 黑名单）
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
# Token 有效期（分钟）。环境变量名必须是 SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES
# 注意：JWT_EXPIRE_MINUTES 不被代码消费，请勿使用。
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===== 凭证加密 =====
# [必改] 凭证（SSH/DB密码等）加密主密钥，独立于 JWT_SECRET。
# 算法：Fernet(AES-128-CBC+HMAC) + PBKDF2-HMAC-SHA256，每条凭证随机盐。
# 未设置时回退到 JWT_SECRET（不推荐）。轮换该值会导致旧密文无法解密。
CREDENTIAL_ENCRYPT_KEY=change_me_in_production

# ===== 初始管理员口令 =====
# 不设置则种子脚本随机生成 16 位口令并打印到日志（仅显示一次）。
# 设置后用此口令作为 admin 初始口令，首次登录后请立即修改。
ADMIN_INITIAL_PASSWORD=

# ===== LLM 配置 =====
# 默认本地 OpenAI 兼容服务；base_url 由环境变量 LLM_BASE_URL 读取，不在代码中硬编码
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL_NAME=qwen3.5-0.8b
LLM_API_KEY=
# 智谱 GLM（z.ai）云端示例：取消下面三行注释即可切换（API Key 在 z.ai 控制台获取）
# LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# LLM_MODEL_NAME=glm-4.6
# LLM_API_KEY=<your-zhipu-api-key>
# 也可在「平台管理-模型服务」页注册模型并设默认（运行时优先于本文件）

# ===== 自动化执行器 =====
# auto: 生产(AUTOPS_ENV=prod)用 ssh 远程执行，其余用 local_dev；也可显式 ssh / local_dev
AUTOPS_EXECUTOR=auto

# ===== 文件产物目录（留空用 <cwd>/data/* 默认）=====
AUTOPS_REPORTS_DIR=                   # 报表 HTML 产物
AUTOPS_BACKUP_DIR=                    # 备份文件
AUTOPS_EXPORT_DIR=                    # 导出 CSV
AUTOPS_UPLOAD_DIR=                    # 工单附件

# ===== 端口 =====
BACKEND_PORT=8001                    # 后端端口（仅绑定 127.0.0.1，由 nginx 反代对外）
FRONTEND_PORT=80                     # 前端 nginx 端口（对外）
