# ============================================
# AUTOPS 环境变量示例
# 复制为 .env 并填写实际值
# ============================================

# ---------- 应用 ----------
APP_NAME=AUTOPS
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- 数据库 ----------
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=autops
DB_USER=autops
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- 凭证加密主密钥 ----------
# 生产环境必须使用安全的随机密钥，不得写入代码
MASTER_ENCRYPTION_KEY=change-me-to-a-secure-random-key

# ---------- 大模型 ----------
LLM_PROVIDER=vllm
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=qwen3.5-0.8b
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# ---------- 时序库 ----------
TIMESERIES_URL=http://127.0.0.1:8428

# ---------- 对象存储 ----------
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=autops

# ---------- 向量库 ----------
VECTOR_STORE_URL=http://127.0.0.1:6333
