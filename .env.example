# AUTOPS 环境变量配置

# 运行环境
AUTOPS_ENV=dev
AUTOPS_CONFIG_DIR=

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=autops
DB_PASS=change_me_in_production
DB_DATABASE=autops

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# 安全 (生产环境必须设置!)
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# LLM 配置
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL_NAME=qwen3.5-0.8b
LLM_API_KEY=

# 凭证加密密钥
CREDENTIAL_ENCRYPT_KEY=change_me_in_production

# 后端
BACKEND_PORT=8001
